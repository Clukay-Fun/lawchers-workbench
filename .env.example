# legal-desens binary path override.
# By default the resolver checks .venv/bin/legal-desens, then PATH.
# Uncomment and set only if you installed legal-desens in a non-standard location.
# LEGAL_DESENS_BIN=/path/to/legal-desens

# Python binary (used only for legacy fallback; prefer the console script)
# PYTHON_BIN=python3

# Redaction timeout in milliseconds
# REDACT_TIMEOUT_MS=120000
