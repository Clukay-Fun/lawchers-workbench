{
  "name": "legal-workbench",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev -w frontend",
    "dev:backend": "npm run start -w backend",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "setup": "bash scripts/setup-engine.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
